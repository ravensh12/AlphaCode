{
  "name": "alphacode",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:curriculum": "vitest run src/content/curricula",
    "test:oracles": "vitest run src/content/curricula/neetcode150/evaluation/oracleEvaluation.test.ts",
    "test:e2e": "playwright test --project=chromium",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov",
    "test:watch": "vitest",
    "lint": "oxlint --max-warnings=17",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build",
    "curriculum:sync-sources": "node scripts/sync-neetcode150-sources.mjs",
    "curriculum:check-links": "node scripts/check-curriculum-links.mjs",
    "assets:fetch": "node scripts/fetch-starter-assets.mjs",
    "assets:optimize": "node scripts/optimize-assets.mjs",
    "assets:bake-citizens": "node scripts/bake-citizen-anim.mjs && node scripts/optimize-assets.mjs --sizes-only",
    "assets:bake-gunshot": "node scripts/bake-gunshot.mjs",
    "meshy:generate": "node scripts/meshy-generate.mjs",
    "meshy:optimize": "node scripts/meshy-optimize.mjs",
    "meshy:verify": "node scripts/meshy-verify.mjs",
    "preview": "vite preview",
    "ai:deploy": "supabase functions deploy ai-tutor --no-verify-jwt",
    "ai:secret": "supabase secrets set OPENAI_API_KEY"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/supabase-js": "^2.108.2",
    "@uiw/react-codemirror": "^4.25.11",
    "meshoptimizer": "^1.2.0",
    "n8ao": "^1.10.2",
    "pyodide": "^314.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "three": "^0.180.0",
    "three-stdlib": "^2.36.1"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.9.0",
    "jsdom": "^29.1.1",
    "ktx2-encoder": "^0.5.3",
    "oxlint": "^1.69.0",
    "sharp": "^0.35.3",
    "supabase": "^2.107.0",
    "syllable": "^5.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.9"
  }
}
