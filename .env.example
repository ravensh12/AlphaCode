# Copy to .env.local and fill in your Supabase project values.
# Supabase dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Use the client-safe key: the "anon" key, or the newer "sb_publishable_..." key.
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Meshy AI (asset generation pipeline: scripts/meshy-*.mjs). Server-side only.
MESHY_API_KEY=

# AI tutor (OpenAI-compatible chat completions). See README "AI tutor".
# ⚠️ VITE_ vars are baked into the client bundle — local/personal use only;
# a public deployment needs a server-side proxy instead of a client key.
#VITE_TUTOR_BASE_URL=https://gateway.truefoundry.ai
#VITE_TUTOR_MODEL=openai-group/gpt-5.4-mini
#VITE_TUTOR_API_KEY=
